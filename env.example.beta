# ==========================================
# Panbox Search Beta - 环境配置文件（可选）
# ==========================================
# 说明：
# 1. Beta 一键脚本会自动生成 /opt/panbox-search-beta/.env
# 2. 手动 docker compose 部署 beta 时，可复制本文件为 .env
# 3. APP_PORT 默认 8088，避免和正式版 80 端口冲突
# ==========================================

# ==================== Docker 镜像与端口 ====================
APP_PORT=8088
PANBOX_IMAGE=kokojacket/panbox-search:beta
PANBOX_POLLER_IMAGE=kokojacket/panbox-openilink-poller:beta

# ==================== 缓存配置 ====================
CACHE_DRIVER=redis
REDIS_PASSWORD=
REDIS_SELECT=0
REDIS_PREFIX=panbox-beta:

# ==================== OpenIlink Poller 配置 ====================
# app 与 panbox-openilink-poller 必须共享同一个内部接口密钥
# 正式部署请改成随机长字符串；一键脚本会自动生成
PANBOX_INTERNAL_TOKEN=change-me
OPENILINK_MAX_CONCURRENCY=300
OPENILINK_CLAIM_LIMIT=300
OPENILINK_POLL_TIMEOUT_MS=1000
OPENILINK_IDLE_SLEEP=3
OPENILINK_BACKEND_TIMEOUT=120

# ==================== Apache Worker 配置 ====================
APACHE_SERVER_LIMIT=32
APACHE_MAX_REQUEST_WORKERS=32
APACHE_START_SERVERS=4
APACHE_MIN_SPARE_SERVERS=4
APACHE_MAX_SPARE_SERVERS=8
